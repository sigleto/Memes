{
  "expo": {
    "name": "Memes",
    "slug": "Memes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Icono.png",
    "scheme": "memes",
    "userInterfaceStyle": "automatic",

    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Memes graba audio para añadirlo a tus memes al compartirlos en vídeo."
      }
    },

    "android": {
      "package": "com.sigleto.Memes",
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/Icono.png"
      },
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_AUDIO",
        "RECORD_AUDIO"
      ]
    },

    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",

      // 👇 NUEVO PLUGIN - COLÓCALO AL PRINCIPIO DEL ARRAY
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.0.21"
          }
        }
      ],

      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-6921150380725872~9048669945"
        }
      ],

      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],

      [
        "expo-media-library",
        {
          "photosPermission": "Permite que Memes guarde tus creaciones en la galería.",
          "savePhotosPermission": "Permite que Memes guarde tus creaciones en la galería."
        }
      ],

      [
        "expo-image-picker",
        {
          "photosPermission": "La app necesita acceder a tus fotos para elegir un meme."
        }
      ],

      "expo-font"
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },

    "extra": {
      "router": {},
      "eas": {
        "projectId": "4d3cea9c-fa3b-4914-8a73-523b039ef6cb"
      }
    }
  }
}
