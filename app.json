{
  "expo": {
    "name": "Memes",
    "slug": "Memes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "memes",
    "userInterfaceStyle": "automatic",

    "ios": {
      "supportsTablet": true
    },

    "android": {
      "package": "com.sigleto.Memes",
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,

      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },

      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES"
      ]
    },

    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",

      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],

      [
        "expo-media-library",
        {
          "photosPermission": "Permite que Memes guarde tus creaciones en la galería.",
          "savePhotosPermission": "Permite que Memes guarde tus creaciones en la galería."
        }
      ],

      [
        "expo-image-picker",
        {
          "photosPermission": "La app necesita acceder a tus fotos para elegir un meme."
        }
      ],

      "expo-font"
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },

    "extra": {
      "router": {},
      "eas": {
        "projectId": "4d3cea9c-fa3b-4914-8a73-523b039ef6cb"
      }
    }
  }
}